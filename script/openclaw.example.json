{
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789,
    "tailscale": {
      "mode": "off"
    },
    "auth": {
      "allowTailscale": false,
      "token": "由 launcher.js 自动生成"
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "user",
    "profiles": {
      "user": {
        "driver": "existing-session",
        "attachOnly": true,
        "color": "#00AA00"
      }
    }
  },
  "models": {
    "providers": {
      "xlb": {
        "baseUrl": "http://xiaoluban.rnd.huawei.com/v1",
        "apiKey": "xxx",
        "api": "openai-completions",
        "models": [
          { "id": "deepseek-r1", "name": "DeepSeek R1" }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "xlb/deepseek-r1"
    }
  },
  "skills": {
    "load": {
      "extraDirs": []
    }
  }
}
