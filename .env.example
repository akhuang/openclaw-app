# Stable mode: preserve existing config, disable risky helpers by default when needed.
# Copy to .env and adjust as required.

# Keep existing plugin/custom fields instead of rebuilding config from template each run.
OPENCLAW_PRESERVE_CONFIG=1

# Skip runtime bundle patching if the installed Control UI changes too often.
OPENCLAW_SKIP_RUNTIME_PATCH=0

# Skip local Welink plugin bootstrap on startup.
OPENCLAW_SKIP_WELINK_BOOTSTRAP=0

# Force-disable the Welink channel in generated config for debugging stability issues.
OPENCLAW_DISABLE_WELINK=0

# Do not auto-open the dashboard in a browser.
OPENCLAW_DISABLE_BROWSER_AUTO_OPEN=0

# OpenClaw CLI log level: silent|fatal|error|warn|info|debug|trace
OPENCLAW_LOG_LEVEL=info

# Optional existing knobs
# OPENCLAW_ENABLE_GATEWAY_REGISTRATION=0
# OPENCLAW_DASHBOARD_OPEN_TIMEOUT_MS=30000
# OPENCLAW_ALLOWED_MODEL_HOSTS=127.0.0.1,localhost,xiaoluban.rnd.huawei.com
# OPENCLAW_BROWSER_HOSTNAME_ALLOWLIST=*.huawei.com,huawei.com
# OPENCLAW_BROWSER_ALLOWED_HOSTNAMES=127.0.0.1,localhost
