# OpenClaw 内网编译配置
# 将此文件放到 openclaw 源码根目录

node-options="--max-old-space-size=16384"

# 跳过 optional 依赖 (node-llama-cpp, @napi-rs/canvas 等)
optional=false

# 跳过 native 包编译，用预构建二进制
ignore-scripts=false

# 不需要的 optional peer dependencies
auto-install-peers=false

# 内网镜像 (按需修改)
# registry=https://你的内网npm镜像地址
